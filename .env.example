# Copy this file to .env.local and fill in your actual API keys

# YouCam AI API
# Free tier: 100 requests/month per feature
# Get key: https://yce.perfectcorp.com/api-console/en
YOUCAM_API_KEY=your_youcam_api_key_here
YOUCAM_API_BASE=https://api.youhealth.perfectcorp.com/v1
YOUCAM_HAIR_ENDPOINT=/hair-style-generator
YOUCAM_INPAINT_ENDPOINT=/inpaint
YOUCAM_STYLE_ENDPOINT=/clothing-style-transfer

# xAI Grok API (Fallback)
# Get key: https://console.x.ai/
XAI_API_KEY=xai_key_here

# OpenAI API (Optional)
# Get key: https://platform.openai.com/
OPENAI_API_KEY=sk-key_here

# App Configuration
APP_ENV=development
APP_DEBUG=false
ENABLE_YOUCAM_HAIR=true
ENABLE_YOUCAM_INPAINT=true
ENABLE_YOUCAM_STYLE=true
ENABLE_GROK_FALLBACK=true
