{
  "expo": {
    "name": "dressai",
    "slug": "dressai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/dressup_ai.png",
    "scheme": "dressai",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f4913f"
      },
      "package": "com.joeldate39.dressai"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/dressup_ai.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "black"
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "76e0bc00-f599-451d-9942-00220e4f19a8"
      }
    }
  }
}
