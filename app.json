{
  "expo": {
    "name": "dressai",
    "slug": "dressai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/dressup_ai.png",
    "scheme": "dressai",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f4913f"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/dressup_ai.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "black"
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
